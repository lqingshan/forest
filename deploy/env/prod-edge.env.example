# Copy to deploy/env/prod-edge.env on the production edge host.

COMPOSE_PROJECT_NAME=forest
FOREST_ENV=prod
FOREST_DOCKER_NETWORK=forest_network
FOREST_CODE_DIR=/home/code/forest
FOREST_GIT_REPO_URL=git@your-git-host:your-org/forest.git

FOREST_GATEWAY_HTTP_PORT=80
FOREST_GATEWAY_HTTPS_PORT=443
FOREST_GATEWAY_SSL_DIR=/home/app/trade-leads/ssl

TRADE_LEADS_BACKEND_NODE_1=backend-node-1:8081
TRADE_LEADS_BACKEND_NODE_2=backend-node-2:8081
