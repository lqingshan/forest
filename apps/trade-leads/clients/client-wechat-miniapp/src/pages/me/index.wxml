<view class="shell-page">
  <view class="shell-stack">
    <text wx:if="{{errorMessage}}" class="shell-error">{{errorMessage}}</text>

    <current-user-card
      user="{{user}}"
      uploading-avatar="{{avatarUploading}}"
      bind:avatarclick="handleChangeAvatar"
    />

    <point-balance-card balance="{{balance}}"/>

    <view class="shell-surface me-actions">
      <button class="shell-button-primary" bindtap="openRecharge">去充值</button>
      <button class="shell-button-ghost" bindtap="openPointLogs">积分流水</button>
      <button class="shell-button-ghost" bindtap="handleLogout">退出登录</button>
    </view>
  </view>

  <bottom-nav current="me"/>
</view>
