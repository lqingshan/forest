.bottom-nav {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  z-index: 20;
}

.bottom-nav__shell {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 248, 0.96);
  box-shadow: 0 18rpx 42rpx rgba(20, 34, 48, 0.16);
  border: 1rpx solid rgba(18, 50, 74, 0.08);
  backdrop-filter: blur(16rpx);
}

.bottom-nav__item {
  flex: 1;
  min-height: 88rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  border-radius: 999rpx;
  color: #677d92;
}

.bottom-nav__item--active {
  background: linear-gradient(135deg, #183750, #2d5f84);
  color: #ffffff;
}

.bottom-nav__label {
  font-size: 24rpx;
  font-weight: 600;
}

.bottom-nav__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.18;
}

.bottom-nav__item--active .bottom-nav__dot {
  opacity: 0.88;
}
