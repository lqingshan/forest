# Copy to apps/trade-leads/env/prod.core.env on the production core host.
# This file only keeps trade-leads backend settings.

TRADE_LEADS_BACKEND_PORT=8081
TRADE_LEADS_WECHAT_PAY_SECRET_DIR=/home/app/trade-leads/wechat-key

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://172.21.11.156:5432/trade_leads_prod?sslmode=disable
SPRING_DATASOURCE_USERNAME=forest
SPRING_DATASOURCE_PASSWORD=lingzhi!@#2026
JWT_SECRET=change-me-to-a-long-random-production-secret
REDIS_HOST=172.21.11.156
REDIS_PORT=6379
REDIS_PASSWORD=forest_redis_shared_2026
REDIS_DATABASE=0

# 短信验证码内容。当前 mock/aliyun 都使用这个验证码值生成短信内容。
# 发送验证码时仍会写入 Redis 和 sms_send_log；登录校验时也必须按 Redis 中的验证码完整消费。
# 未配置时后端默认使用 121314；生产真实使用时建议改成随机生成能力后再调整此项。
AUTH_SMS_CODE=121314
# 短信供应商：
# - aliyun：真实调用阿里云短信，生产签名和模板审核通过后使用。
# - mock：只跳过真实短信发送，其它 Redis / 日志 / 校验流程保持一致，适合未申请签名时联调。
# - disabled：关闭短信发送能力，验证码登录不可用。
FOREST_SMS_PROVIDER=aliyun
# 阿里云短信签名名称，需要与阿里云控制台审核通过的签名一致。
FOREST_SMS_DEFAULT_SIGN_NAME=your-sms-sign-name
# 默认短信模板编码。验证码场景优先使用 FOREST_SMS_VERIFICATION_TEMPLATE_CODE；这里可留空。
FOREST_SMS_DEFAULT_TEMPLATE_CODE=
# 验证码短信模板编码，需要与阿里云控制台审核通过的模板一致。
# 当前后端模板参数固定为 {"code":"验证码"}。
FOREST_SMS_VERIFICATION_TEMPLATE_CODE=SMS_XXXXXX
# 短信日志内容保存策略：
# - NONE：不保存短信内容快照。
# - MASKED：验证码全量脱敏。
# - MASKED_PARTIAL：只保留验证码尾部若干位，便于排查且不暴露完整验证码。
# - PLAIN：保存完整短信内容，仅建议本地或临时排查使用。
FOREST_SMS_LOG_CONTENT_MODE=MASKED_PARTIAL
# MASKED_PARTIAL 模式下保留验证码尾部几位，例如 2 表示 ******56。
FOREST_SMS_LOG_MASK_VISIBLE_TAIL=2
# 阿里云短信 OpenAPI endpoint，国内短信通常使用 dysmsapi.aliyuncs.com。
FOREST_SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com
# 阿里云短信访问密钥。生产建议使用权限收敛后的 RAM 用户，不要复用主账号 AccessKey。
FOREST_SMS_ALIYUN_ACCESS_KEY_ID=
FOREST_SMS_ALIYUN_ACCESS_KEY_SECRET=
# 验证码有效期，超时后 Redis 中的验证码自动失效。
FOREST_VERIFICATION_SMS_CODE_TTL=5m
# 单个验证码最多允许输错次数，超过后需要重新发送。
FOREST_VERIFICATION_SMS_MAX_ATTEMPTS=5
# 同一手机号同一场景的发送冷却时间，避免频繁点击发送。
FOREST_VERIFICATION_SMS_SEND_INTERVAL=60s
# 同一手机号同一场景每日最大发送次数。
FOREST_VERIFICATION_SMS_DAILY_LIMIT=10
# 验证通过后签发的一次性 ticket 有效期；登录场景暂不依赖 ticket。
FOREST_VERIFICATION_TICKET_TTL=10m

# APP 原生本机号一键登录供应商：
# - disabled：关闭本机号一键登录能力，当前生产默认关闭。
# - mock：使用 FOREST_CARRIER_AUTH_MOCK_PHONE 模拟取号，适合本地联调。
# - aliyun：真实调用阿里云号码认证服务。
FOREST_CARRIER_AUTH_PROVIDER=disabled
# 仅在 FOREST_CARRIER_AUTH_PROVIDER=mock 时生效，用于模拟运营商返回的手机号。
FOREST_CARRIER_AUTH_MOCK_PHONE=+8613800138000
# 阿里云号码认证 OpenAPI endpoint。
FOREST_CARRIER_AUTH_ALIYUN_ENDPOINT=dypnsapi.aliyuncs.com
# 阿里云号码认证访问密钥，真实启用 aliyun provider 时必填。
FOREST_CARRIER_AUTH_ALIYUN_ACCESS_KEY_ID=
FOREST_CARRIER_AUTH_ALIYUN_ACCESS_KEY_SECRET=

FOREST_FILE_ENV=prod
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your-oss-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
TRADE_LEADS_OSS_BUCKET=trade-leads

TRADE_LEADS_MINIAPP_APPID=wx-your-prod-appid
TRADE_LEADS_MINIAPP_SECRET=change-me
TRADE_LEADS_MINIAPP_MOCK_ENABLED=false

WECHAT_PAY_ENABLED=true
WECHAT_PAY_MOCK_ENABLED=false
WECHAT_PAY_MCH_ID=change-me
WECHAT_PAY_APPID=wx-your-prod-appid
WECHAT_PAY_MERCHANT_SERIAL_NO=change-me
WECHAT_PAY_API_V3_KEY=change-me
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat-pay/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=PUB_KEY_ID_change-me
WECHAT_PAY_PUBLIC_KEY_PATH=/run/secrets/wechat-pay/wechatpay_public_key.pem
WECHAT_PAY_NOTIFY_URL=https://api.yourdomain.com/api/open/wechat/pay/notify
