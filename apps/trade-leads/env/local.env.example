# Copy to apps/trade-leads/env/local.env for local development.

TRADE_LEADS_BACKEND_PORT=8081
TRADE_LEADS_WECHAT_PAY_SECRET_DIR=/absolute/path/to/forest/apps/trade-leads/wechat/merchant/cert

SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://8.136.34.70:5432/trade_leads_local?sslmode=disable
SPRING_DATASOURCE_USERNAME=forest
SPRING_DATASOURCE_PASSWORD=lingzhi!@#2026
JWT_SECRET=your-secret-key-must-be-at-least-256-bits-long-for-security
REDIS_HOST=8.136.34.70
REDIS_PORT=6379
REDIS_PASSWORD=forest_redis_shared_2026
REDIS_DATABASE=1

# 短信验证码内容。发送验证码时会写入 Redis 和短信日志；校验时仍按完整 Redis 流程消费。
# 未配置时后端默认使用 121314。
AUTH_SMS_CODE=121314
# mock 会走完整短信发送流程，但不调用真实短信供应商，适合阿里云签名/模板未审核前调试。
FOREST_SMS_PROVIDER=mock
FOREST_SMS_DEFAULT_SIGN_NAME=your-sms-sign-name
FOREST_SMS_DEFAULT_TEMPLATE_CODE=
FOREST_SMS_VERIFICATION_TEMPLATE_CODE=SMS_XXXXXX
# PLAIN 会在 sms_send_log 中保存短信内容明文，方便本地排查；生产环境不要使用。
FOREST_SMS_LOG_CONTENT_MODE=PLAIN
FOREST_SMS_LOG_MASK_VISIBLE_TAIL=2
FOREST_VERIFICATION_SMS_CODE_TTL=5m
FOREST_VERIFICATION_SMS_MAX_ATTEMPTS=5
FOREST_VERIFICATION_SMS_SEND_INTERVAL=60s
FOREST_VERIFICATION_SMS_DAILY_LIMIT=10
FOREST_VERIFICATION_TICKET_TTL=10m
FOREST_CARRIER_AUTH_PROVIDER=disabled
FOREST_CARRIER_AUTH_MOCK_PHONE=+8613800138000
FOREST_CARRIER_AUTH_ALIYUN_ENDPOINT=dypnsapi.aliyuncs.com
FOREST_CARRIER_AUTH_ALIYUN_ACCESS_KEY_ID=
FOREST_CARRIER_AUTH_ALIYUN_ACCESS_KEY_SECRET=

FOREST_FILE_ENV=local
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your-oss-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
TRADE_LEADS_OSS_BUCKET=trade-leads

TRADE_LEADS_MINIAPP_APPID=wx-your-appid
TRADE_LEADS_MINIAPP_SECRET=your-secret
TRADE_LEADS_MINIAPP_MOCK_ENABLED=false

# Keep mock enabled for ordinary local development.
# Set WECHAT_PAY_ENABLED=true and WECHAT_PAY_MOCK_ENABLED=false only when testing real WeChat Pay locally.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MOCK_ENABLED=true
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APPID=wx-your-appid
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat-pay/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_PUBLIC_KEY_PATH=/run/secrets/wechat-pay/wechatpay_public_key.pem
WECHAT_PAY_NOTIFY_URL=http://localhost:8081/api/open/wechat/pay/notify
