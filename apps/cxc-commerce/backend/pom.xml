<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.forest</groupId>
        <artifactId>forest-backend-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../../../base-backend/pom.xml</relativePath>
    </parent>

    <groupId>com.forest.apps</groupId>
    <artifactId>forest-app-cxc-commerce</artifactId>
    <packaging>jar</packaging>

    <dependencies>
        <dependency>
            <groupId>com.forest</groupId>
            <artifactId>forest-starter-common</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest</groupId>
            <artifactId>forest-starter-auth</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest</groupId>
            <artifactId>forest-starter-redis</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest</groupId>
            <artifactId>forest-starter-sms</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest</groupId>
            <artifactId>forest-starter-object-storage</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest</groupId>
            <artifactId>forest-starter-ocr</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-business-user</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-business-notification</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-business-verification</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-business-file</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-business-access</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-business-organization</artifactId>
        </dependency>
        <dependency>
            <groupId>com.forest.business</groupId>
            <artifactId>forest-aggregation-organization-access</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <executions>
                    <execution>
                        <id>copy-user-flyway-migrations</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.outputDirectory}/db/migration</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${project.basedir}/../../../business/domains/user/backend/src/main/resources/db/migration</directory>
                                    <filtering>false</filtering>
                                </resource>
                                <resource>
                                    <directory>${project.basedir}/../../../business/domains/notification/backend/src/main/resources/db/migration</directory>
                                    <filtering>false</filtering>
                                </resource>
                                <resource>
                                    <directory>${project.basedir}/../../../business/domains/file/backend/src/main/resources/db/migration</directory>
                                    <filtering>false</filtering>
                                </resource>
                                <resource>
                                    <directory>${project.basedir}/../../../business/domains/access/backend/src/main/resources/db/migration</directory>
                                    <filtering>false</filtering>
                                </resource>
                                <resource>
                                    <directory>${project.basedir}/../../../business/domains/organization/backend/src/main/resources/db/migration</directory>
                                    <filtering>false</filtering>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <goals><goal>repackage</goal></goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
