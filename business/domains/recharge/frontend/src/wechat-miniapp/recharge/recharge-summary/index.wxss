.recharge-summary {
  padding: 30rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #12324a, #1d5b7c 58%, #6db1ba);
  color: #ffffff;
  box-shadow: 0 24rpx 54rpx rgba(18, 50, 74, 0.22);
}

.recharge-summary__eyebrow {
  font-size: 22rpx;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.72;
}

.recharge-summary__title {
  display: block;
  margin-top: 14rpx;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 700;
}

.recharge-summary__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.9;
}
