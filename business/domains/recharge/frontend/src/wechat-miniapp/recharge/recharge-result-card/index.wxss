.recharge-result-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recharge-result-card__hero {
  padding: 30rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #12324a, #1d5b7c 58%, #6db1ba);
  color: #ffffff;
  box-shadow: 0 24rpx 54rpx rgba(18, 50, 74, 0.22);
}

.recharge-result-card__hero--success {
  background: linear-gradient(145deg, #0f6b5b, #17a37a 58%, #7bc8a4);
}

.recharge-result-card__hero--cancelled,
.recharge-result-card__hero--failed {
  background: linear-gradient(145deg, #5f3521, #9a5f26 58%, #d59b58);
}

.recharge-result-card__eyebrow {
  font-size: 22rpx;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.72;
}

.recharge-result-card__title {
  display: block;
  margin-top: 14rpx;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 700;
}

.recharge-result-card__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.9;
}

.recharge-result-card__surface {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
}

.recharge-result-card__row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #1f374a;
}

.recharge-result-card__label {
  color: #677b8f;
}
