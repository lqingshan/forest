.point-log-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.point-log-list__empty {
  padding: 42rpx 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
  text-align: center;
  color: #60758a;
}

.point-log-list__item {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
}

.point-log-list__amount {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.point-log-list__amount--income {
  color: #0f7b5e;
}

.point-log-list__amount--spend {
  color: #b35a22;
}

.point-log-list__source {
  display: block;
  margin-top: 8rpx;
  color: #63778a;
  font-size: 26rpx;
}

.point-log-list__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  color: #4a6379;
  font-size: 24rpx;
}
