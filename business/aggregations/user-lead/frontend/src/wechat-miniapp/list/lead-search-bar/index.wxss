.lead-search-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  align-items: center;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
}

.lead-search-bar__input {
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  padding: 0 26rpx;
  background: rgba(13, 33, 48, 0.05);
  border: 1rpx solid rgba(13, 33, 48, 0.08);
}

.lead-search-bar__button {
  width: 180rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
  background: linear-gradient(135deg, #17324d, #315f86);
  color: #ffffff;
}
