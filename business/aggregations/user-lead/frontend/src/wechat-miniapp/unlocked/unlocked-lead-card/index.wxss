.unlocked-lead-card {
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
}

.unlocked-lead-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.unlocked-lead-card__name {
  font-size: 34rpx;
  font-weight: 700;
  color: #12324a;
}

.unlocked-lead-card__pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(16, 145, 102, 0.12);
  color: #0f7b5e;
}

.unlocked-lead-card__meta {
  font-size: 26rpx;
  color: #63778a;
}

.unlocked-lead-card__contact {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #20364a;
}
