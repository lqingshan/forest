.lead-detail-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.lead-detail-card__hero {
  padding: 30rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #12324a, #1d5b7c 58%, #6db1ba);
  color: #ffffff;
  box-shadow: 0 24rpx 54rpx rgba(18, 50, 74, 0.22);
}

.lead-detail-card__eyebrow {
  font-size: 22rpx;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.72;
}

.lead-detail-card__title {
  display: block;
  margin-top: 14rpx;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 700;
}

.lead-detail-card__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.9;
}

.lead-detail-card__surface {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
}

.lead-detail-card__row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(18, 50, 74, 0.04);
  color: #1e364a;
}

.lead-detail-card__label {
  color: #687d91;
  font-size: 24rpx;
}
