.lead-unlock-panel {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(27, 44, 58, 0.09);
  border: 1rpx solid rgba(29, 44, 55, 0.06);
}

.lead-unlock-panel--success {
  background: linear-gradient(145deg, rgba(15, 123, 94, 0.08), rgba(255, 255, 255, 0.96));
}

.lead-unlock-panel__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #17324d;
}

.lead-unlock-panel__desc {
  color: #60758a;
  line-height: 1.7;
  font-size: 28rpx;
}

.lead-unlock-panel__button {
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
  background: linear-gradient(135deg, #0f6b5b, #17a37a);
  color: #ffffff;
  box-shadow: 0 16rpx 30rpx rgba(15, 107, 91, 0.18);
}
